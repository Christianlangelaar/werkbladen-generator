{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "noEmit": true,
    "lib": ["ES2024", "DOM"],
    "types": ["node"]
  },
  "include": [
    "./*.ts",
    "../server/**/*.ts",
    "../shared/**/*.ts",
    "../prompts/**/*.ts"
  ],
  "exclude": ["**/*.test.ts"]
}
